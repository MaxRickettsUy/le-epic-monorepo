# Copy to .env and adjust. Consumed by docker-compose.yml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hc_archives_back

# Optional: override the SQLAlchemy URL when running the app outside Docker.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hc_archives_back

# MusicBrainz dump Postgres (metabrainz/musicbrainz-docker), used by the seeder.
# MB_DATABASE_URL=postgresql+psycopg2://musicbrainz:musicbrainz@localhost:5433/musicbrainz_db

# Contact email sent in the MusicBrainz web-API user-agent (their API etiquette).
# Required: set this to a real contact address for your deployment.
MUSICBRAINZ_CONTACT_EMAIL=support@example.com
